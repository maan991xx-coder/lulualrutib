<script>
// ═══════════════════════════════════════
// GOOGLE APPS SCRIPT ENDPOINT
// Replace with your actual deployed Apps Script Web App URL
// ═══════════════════════════════════════
const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec';

// ═══════════════════════════════════════
// PAYMENT GATEWAY URL
// Replace with your actual payment gateway link
// ═══════════════════════════════════════
const PAYMENT_URL = 'https://YOUR-PAYMENT-GATEWAY.com/pay';

// ─────────────────────────────
// State
// ─────────────────────────────
let currentSelection = {
  section: null,
  badge: null,
  amount: null,
  qty: null
};

// ─────────────────────────────
// Card selection
// ─────────────────────────────
function selectCard(card, section, badge, amount, qty) {
  // Deselect all in same grid
  const grid = document.getElementById(section + '-cards');
  grid.querySelectorAll('.price-card').forEach(c => c.classList.remove('selected'));

  // Select clicked
  card.classList.add('selected');

  // Store state
  currentSelection = { section, badge, amount, qty };

  // Update info text
  const info = document.getElementById(section + '-info');
  info.innerHTML = `✅ اخترت <strong>${badge}</strong> — ${amount} ريال | ${qty}`;
  info.style.color = '#2d5a20';

  // Activate pay button
  const btn = document.getElementById(section + '-pay-btn');
  btn.classList.add('active');
}

// ─────────────────────────────
// Modal
// ─────────────────────────────
function openModal(section) {
  if (!currentSelection.section || currentSelection.section !== section) return;

  const isWater = section === 'water';
  document.getElementById('modal-icon').textContent = isWater ? '💧' : '📖';
  document.getElementById('modal-title').textContent = isWater
    ? 'تأكيد التبرع — سقيا يوم عرفة'
    : 'تأكيد التبرع — نور عُمان';
  document.getElementById('s-project').textContent = isWater
    ? 'سقيا يوم عرفة' : 'نور عُمان لتوزيع المصاحف';
  document.getElementById('s-package').textContent = currentSelection.badge;
  document.getElementById('s-qty').textContent = currentSelection.qty;
  document.getElementById('s-amount').textContent = currentSelection.amount + ' ريال عُماني';

  // Reset form
  document.getElementById('donor-name').value = '';
  document.getElementById('donor-phone').value = '';
  document.getElementById('modal-form-section').style.display = '';
  document.getElementById('modal-success').style.display = 'none';
  document.getElementById('confirm-btn').disabled = false;
  document.getElementById('confirm-btn').textContent = 'المتابعة إلى الدفع 🔒';

  document.getElementById('payModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('payModal').classList.remove('open');
  document.body.style.overflow = '';
}

// Close on overlay click
document.getElementById('payModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ─────────────────────────────
// Confirm & submit
// ─────────────────────────────
async function confirmPayment() {
  const name = document.getElementById('donor-name').value.trim();
  const phone = document.getElementById('donor-phone').value.trim();

  if (!name) { alert('يرجى إدخال اسمك الكريم'); return; }
  if (!phone) { alert('يرجى إدخال رقم الهاتف'); return; }

  const btn = document.getElementById('confirm-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> جاري المعالجة...';

  const now = new Date();
  const payload = {
    name,
    phone,
    project: currentSelection.section === 'water' ? 'سقيا يوم عرفة' : 'نور عُمان لتوزيع المصاحف',
    package: currentSelection.badge,
    amount: currentSelection.amount,
    qty: currentSelection.qty,
    date: now.toLocaleDateString('ar-SA'),
    time: now.toLocaleTimeString('ar-SA'),
    status: 'pending'
  };

  // ── Send to Google Sheets ──
  try {
    await fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
  } catch (e) {
    console.warn('Google Sheets logging failed:', e);
    // Non-blocking — proceed to payment anyway
  }

  // ── Show success ──
  document.getElementById('modal-form-section').style.display = 'none';
  document.getElementById('modal-success').style.display = 'block';

  // ── Redirect to payment gateway after 1.8s ──
  setTimeout(() => {
    const params = new URLSearchParams({
      amount: currentSelection.amount,
      description: payload.project + ' — ' + payload.package,
      name,
      phone
    });
    // Redirect to payment URL with params
    window.open(PAYMENT_URL + '?' + params.toString(), '_blank');
    closeModal();
  }, 1800);
}

// ─────────────────────────────
// Scroll animations
// ─────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 80);
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>

